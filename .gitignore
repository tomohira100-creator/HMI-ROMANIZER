# OS
.DS_Store
Thumbs.db

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/
.coverage
.pytest_cache/

# Node / Frontend
node_modules/
dist/
.vite/

# Rust / Tauri
target/
src-tauri/target/

# Build outputs
*.msi
*.exe

# Samples (often large, keep them local only).
# Real HMI documents must never be committed. Redaction is not a security
# boundary this project relies on, so exclusion is enforced here rather than
# by discipline. Only the deterministically synthesized fixtures are tracked.
samples/*
!samples/README.md
!samples/05_lists.docx
!samples/10_composite.docx
!samples/11_fragmented.docx
!samples/12_spreadsheet.xlsx

# Logs and temp
*.log
.tmp/
